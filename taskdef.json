{
  "family": "strapi-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "REPLACED_BY_GITHUB_ACTION",
  "containerDefinitions": [
    {
      "name": "strapi",
      "image": "811738701312.dkr.ecr.us-east-1.amazonaws.com/strapi:latest",
      "portMappings": [
        {
          "containerPort": 1337,
          "protocol": "tcp"
        }
      ],
      "essential": true
    }
  ]
}